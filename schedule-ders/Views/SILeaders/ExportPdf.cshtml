@model schedule_ders.ViewModels.SILeaderAdminIndexViewModel
@{
    Layout = null;
    var generated = DateTime.Now;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.ExportTitle</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 1rem;
            color: #1b2d42;
        }
        h1 {
            margin: 0 0 0.35rem 0;
            font-size: 1.6rem;
        }
        .meta {
            margin-bottom: 1rem;
            color: #46627e;
            font-size: 0.92rem;
        }
        table {
            border-collapse: collapse;
            width: 100%;
        }
        th, td {
            border: 1px solid #9db4cc;
            padding: 0.45rem 0.5rem;
            text-align: left;
            vertical-align: top;
            font-size: 0.9rem;
        }
        th {
            background: #eaf2fb;
        }
        .toolbar {
            margin-bottom: 1rem;
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }
        .btn {
            border: 1px solid #5f89b4;
            border-radius: 8px;
            background: #f4f8fd;
            color: #1e4d79;
            padding: 0.35rem 0.7rem;
            font-size: 0.85rem;
            cursor: pointer;
        }
        @@media print {
            .toolbar { display: none; }
            body { margin: 0.35in; }
        }
    </style>
</head>
<body>
    <div class="toolbar">
        <button type="button" class="btn" onclick="window.print()">Print / Save as PDF</button>
    </div>
    <h1>@Model.ExportTitle</h1>
    <div class="meta">
        Generated: @generated.ToString("f")
        @if (!string.IsNullOrWhiteSpace(Model.Search))
        {
            <text> | Filter: @Model.Search</text>
        }
    </div>
    <table>
        <thead>
            <tr>
                @if (Model.ShowANumber)
                {
                    <th>@Model.ExportANumberLabel</th>
                }
                @if (Model.ShowLeaderName)
                {
                    <th>@Model.ExportLeaderNameLabel</th>
                }
                @if (Model.ShowCoursesTeaching)
                {
                    <th>@Model.ExportCoursesTeachingLabel</th>
                }
                @if (Model.ShowSectionNumbers)
                {
                    <th>@Model.ExportSectionNumbersLabel</th>
                }
                @foreach (var field in Model.CustomFields)
                {
                    <th>@field.Name</th>
                }
            </tr>
        </thead>
        <tbody>
        @if (!Model.Leaders.Any())
        {
            <tr>
                <td colspan="@((Model.ShowANumber ? 1 : 0) + (Model.ShowLeaderName ? 1 : 0) + (Model.ShowCoursesTeaching ? 1 : 0) + (Model.ShowSectionNumbers ? 1 : 0) + Model.CustomFields.Count)">No SI leaders found.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.Leaders)
            {
                <tr>
                    @if (Model.ShowANumber)
                    {
                        <td>@item.ANumber</td>
                    }
                    @if (Model.ShowLeaderName)
                    {
                        <td>@item.LeaderName</td>
                    }
                    @if (Model.ShowCoursesTeaching)
                    {
                        <td>@item.CoursesTeaching</td>
                    }
                    @if (Model.ShowSectionNumbers)
                    {
                        <td>@item.SectionNumbers</td>
                    }
                    @foreach (var field in Model.CustomFields)
                    {
                        <td>
                            @(item.CustomFieldValues.TryGetValue(field.SILeaderCustomFieldId, out var value) && !string.IsNullOrWhiteSpace(value)
                                ? value
                                : "-")
                        </td>
                    }
                </tr>
            }
        }
        </tbody>
    </table>
</body>
</html>
