@model schedule_ders.Models.Session
@{
    ViewData["Title"] = "Delete Session";
}

<section class="page-shell">
<h1 class="page-title">Delete Session</h1>
<p class="page-subtitle">Course: @ViewData["CourseName"]</p>
<p class="text-danger">Are you sure you want to delete this session?</p>

<dl class="row surface-card p-3">
    <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Day)</dt>
    <dd class="col-sm-10">@Model.Day</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Time)</dt>
    <dd class="col-sm-10">@Model.Time</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Location)</dt>
    <dd class="col-sm-10">@Model.Location</dd>
</dl>

<form asp-action="Delete" method="post" class="form-card">
    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
    <input type="hidden" asp-for="SessionID" />
    <button type="submit" class="btn btn-danger">Delete</button>
    @if (ViewData["ReturnUrl"] is string returnUrl && !string.IsNullOrWhiteSpace(returnUrl))
    {
        <a href="@returnUrl" class="btn btn-secondary">Cancel</a>
    }
    else
    {
        <a asp-controller="Sessions" asp-action="Index" class="btn btn-secondary">Cancel</a>
    }
</form>
</section>
