@model schedule_ders.ViewModels.StudentScheduleSearchViewModel
@{
    ViewData["Title"] = "SI Schedule";
    var dayOptions = ViewData["DayOptions"] as List<string> ?? [];
    var semesterOptions = ViewData["SemesterOptions"] as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    static int GetDaySortOrder(string? day) => day?.Trim().ToLowerInvariant() switch
    {
        "monday" => 1,
        "tuesday" => 2,
        "wednesday" => 3,
        "thursday" => 4,
        "friday" => 5,
        "saturday" => 6,
        "sunday" => 7,
        _ => 99
    };
    var groupedResults = Model.Results
        .GroupBy(r => new { r.CourseName, r.CourseTitle, r.Professor, r.SILeader })
        .Select(g => new
        {
            g.Key.CourseName,
            g.Key.CourseTitle,
            g.Key.Professor,
            g.Key.SILeader,
            Sections = g
                .GroupBy(x => new { x.CourseID, x.CourseSection })
                .Select(x => new
                {
                    x.Key.CourseID,
                    x.Key.CourseSection
                })
                .OrderBy(x => x.CourseSection)
                .ToList(),
            Sessions = g
                .GroupBy(x => new { x.Day, x.Time, x.Location })
                .Select(x => x.First())
                .OrderBy(x => GetDaySortOrder(x.Day))
                .ThenBy(x => x.Day)
                .ThenBy(x => x.Time)
                .ToList()
        })
        .OrderByDescending(g => g.Sections.Any(s => Model.FavoriteCourseIds.Contains(s.CourseID)))
        .ThenBy(g => g.CourseName)
        .ToList();
    var mergedSessionCount = groupedResults.Sum(g => g.Sessions.Count);
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
    var timeSuggestions = new List<string>();
    for (var hour = 6; hour <= 22; hour++)
    {
        foreach (var minute in new[] { 0, 15, 30, 45, 50 })
        {
            var displayHour = hour % 12 == 0 ? 12 : hour % 12;
            var suffix = hour >= 12 ? "pm" : "am";
            timeSuggestions.Add($"{displayHour}:{minute:00}{suffix}");
        }
    }
}

<section class="student-schedule-page page-shell">
    <div class="student-schedule-hero mb-4">
        <h1 class="mb-2">Find SI Sessions</h1>
        <p class="mb-0">Search by course, day, professor, or location. Each course card below shows all matching SI sessions.</p>
    </div>

    <div class="card shadow-sm mb-2">
        <div class="card-body">
            <form asp-action="Index"
                  method="get"
                  class="row g-2 align-items-end"
                  data-student-schedule-form="true"
                  data-api-url="@Url.Content("~/api/v1/schedule/sessions")">
                <div class="col-lg-4">
                    <label class="form-label mb-1">Search</label>
                    <input name="search"
                           value="@Model.Search"
                           class="form-control"
                           placeholder="Course, section, location, or SI leader" />
                </div>
                <div class="col-lg-2">
                    <label class="form-label mb-1">Time</label>
                    <input name="time"
                           value="@Model.Time"
                           class="form-control"
                           list="student-search-time-options"
                           placeholder="e.g. 10:03 or 1003" />
                    <datalist id="student-search-time-options">
                        @foreach (var option in timeSuggestions)
                        {
                            <option value="@option"></option>
                        }
                    </datalist>
                </div>
                <div class="col-lg-2">
                    <label class="form-label mb-1">Day</label>
                    <select name="day" class="form-select">
                        <option value="">All days</option>
                        @foreach (var day in dayOptions)
                        {
                            if (Model.Day == day)
                            {
                                <option value="@day" selected>@day</option>
                            }
                            else
                            {
                                <option value="@day">@day</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-lg-2">
                    <label class="form-label mb-1">Professor</label>
                    <input name="professor" value="@Model.Professor" class="form-control" placeholder="Professor name" />
                </div>
                <div class="col-lg-2">
                    <label class="form-label mb-1">Semester</label>
                    <select name="semesterId" class="form-select" asp-items="semesterOptions">
                        <option value="">All semesters</option>
                    </select>
                </div>
                <div class="col-lg-2 d-grid">
                    <button type="submit" class="btn btn-primary">Apply</button>
                </div>
            </form>
            <div class="mt-2">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear Filters</a>
            </div>
        </div>
    </div>

    <div class="student-schedule-meta mb-3">
        <div class="student-meta-pill">Courses: <span data-student-course-count="true">@groupedResults.Count</span></div>
        <div class="student-meta-pill">Sessions: <span data-student-session-count="true">@mergedSessionCount</span></div>
    </div>

    @if (!groupedResults.Any())
    {
        <div class="alert alert-secondary">No SI sessions match the selected filters.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var course in groupedResults)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="card h-100 shadow-sm student-course-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between flex-wrap gap-2 mb-2">
                                <h2 class="h5 mb-0">
                                    <span class="fw-bold">@course.CourseName</span>
                                    @if (!string.IsNullOrWhiteSpace(course.CourseTitle))
                                    {
                                        <span class="text-muted"> - @course.CourseTitle</span>
                                    }
                                </h2>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge student-section-badge">Sections @string.Join(", ", course.Sections.Select(s => s.CourseSection))</span>
                                    @if (Model.CanManageFavorites)
                                    {
                                        var sectionIds = course.Sections.Select(s => s.CourseID).Distinct().ToList();
                                        var isFavorite = sectionIds.Count > 0 && sectionIds.All(id => Model.FavoriteCourseIds.Contains(id));
                                        <form method="post"
                                              asp-action="@(isFavorite ? "UnfavoriteGroup" : "FavoriteGroup")"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()
                                            @foreach (var sectionId in sectionIds)
                                            {
                                                <input type="hidden" name="courseIds" value="@sectionId" />
                                            }
                                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                                            <button type="submit" class="btn btn-sm @(isFavorite ? "btn-warning" : "btn-outline-secondary")">
                                                @(isFavorite ? "Favorited" : "Add Favorite")
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
                                <span class="badge session-meta-badge session-meta-badge-professor">Professor: @course.Professor</span>
                                <span class="badge session-meta-badge session-meta-badge-leader">SI Leader: @course.SILeader</span>
                            </div>

                            <div class="d-flex flex-column gap-2">
                                @foreach (var session in course.Sessions)
                                {
                                    <div class="student-session-item">
                                        <div class="student-session-day">@session.Day</div>
                                        <div class="student-session-time">@session.Time</div>
                                        <div class="student-session-location">@session.Location</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>
