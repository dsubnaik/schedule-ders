@{
    ViewData["Title"] = "Professor Dashboard";
}

<section class="page-shell py-2">
    <h1 class="page-title">Professor Dashboard</h1>
    <p class="page-subtitle">You are signed in with the <strong>Professor</strong> role.</p>
    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h5">SI Requests</h2>
            <p class="mb-3">Submit new SI requests and track progress from submission to decision.</p>
            <a class="btn btn-primary" asp-controller="ProfessorRequests" asp-action="Index">Open My Requests</a>
        </div>
    </div>
</section>
