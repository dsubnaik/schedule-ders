@model IEnumerable<schedule_ders.Models.SIRequest>
@{
    ViewData["Title"] = "SI Requests";
}

<section class="page-shell">
<div class="page-header mb-1">
    <h1 class="page-title">SI Requests</h1>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3 surface-card surface-toolbar">
    <div class="col-md-4">
        <select name="status" class="form-select" asp-items="ViewBag.Statuses">
            <option value="">All statuses</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
    </div>
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-link">Clear</a>
    </div>
</form>

<div class="table-responsive data-table">
    <table class="table table-striped align-middle data-table-compact">
        <thead>
            <tr>
                <th>Course</th>
                <th>Professor</th>
                <th>Submitted</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-muted">No SI requests found.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                var courseDisplay = item.Course is not null
                    ? $"{item.Course.CourseName} ({item.Course.CourseSection})"
                    : (!string.IsNullOrWhiteSpace(item.RequestedCourseName)
                        ? $"{item.RequestedCourseName} ({item.RequestedCourseSection})"
                        : "Manual Course Entry");
                <tr>
                    <td>@courseDisplay</td>
                    <td>@item.ProfessorName</td>
                    <td>@item.SubmittedAtUtc.ToLocalTime().ToString("g")</td>
                    <td>
                        <span class="status-pill @(item.Status switch
                            {
                                schedule_ders.Models.SIRequestStatus.Pending => "status-pill-pending",
                                schedule_ders.Models.SIRequestStatus.UnderReview => "status-pill-review",
                                schedule_ders.Models.SIRequestStatus.Approved => "status-pill-approved",
                                _ => "status-pill-denied"
                            })">@item.Status</span>
                    </td>
                    <td><a asp-action="Update" asp-route-id="@item.SIRequestID">Review</a></td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
</section>
