@model IEnumerable<schedule_ders.Models.SIRequest>
@{
    ViewData["Title"] = "SI Requests";
    var nowUtc = DateTime.UtcNow;

    string RelativeTime(DateTime utc, DateTime now)
    {
        var delta = now - utc;
        if (delta.TotalMinutes < 1) return "just now";
        if (delta.TotalHours < 1) return $"{Math.Max(1, (int)delta.TotalMinutes)} min ago";
        if (delta.TotalDays < 1) return $"{Math.Max(1, (int)delta.TotalHours)}h ago";
        if (delta.TotalDays < 7) return $"{Math.Max(1, (int)delta.TotalDays)}d ago";
        if (delta.TotalDays < 31) return $"{Math.Max(1, (int)(delta.TotalDays / 7))}w ago";
        if (delta.TotalDays < 365) return $"{Math.Max(1, (int)(delta.TotalDays / 30))}mo ago";
        return $"{Math.Max(1, (int)(delta.TotalDays / 365))}y ago";
    }
}

<section class="page-shell">
<div class="page-header mb-1">
    <h1 class="page-title">SI Requests</h1>
</div>

<form asp-action="Index"
      method="get"
      class="row g-2 mb-3 admin-requests-toolbar"
      data-admin-requests-filter="true"
      data-api-url="@Url.Content("~/api/v1/admin/requests")"
      data-review-url-template="@Url.Action("Update", "AdminRequests", new { id = "__id__" })"
      data-remove-api-url-template="@Url.Content("~/api/v1/admin/requests/__id__")">
    <input type="hidden" name="status" value="@(Context.Request.Query["status"])" />
    <div class="col-12">
        <div class="quick-status-chips" data-admin-status-chips="true">
            <button type="button" class="quick-status-chip" data-status-value="">All</button>
            <button type="button" class="quick-status-chip" data-status-value="Pending">Pending</button>
            <button type="button" class="quick-status-chip" data-status-value="UnderReview">Under Review</button>
            <button type="button" class="quick-status-chip" data-status-value="Approved">Approved</button>
            <button type="button" class="quick-status-chip" data-status-value="SiLeaderFound">SI Leader Found</button>
            <button type="button" class="quick-status-chip" data-status-value="Denied">Not Moving Forward</button>
        </div>
    </div>
</form>

<div class="table-responsive data-table admin-requests-table-scroll">
    <table class="table table-striped align-middle data-table-compact admin-requests-table admin-requests-table-compact">
        <caption>Supplemental instruction requests with professor, submission date, review status, and actions.</caption>
        <thead>
            <tr>
                <th scope="col">Course</th>
                <th scope="col">Professor</th>
                <th scope="col">Submitted</th>
                <th scope="col">Status</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody data-admin-requests-tbody="true">
        @if (!Model.Any())
        {
            <tr>
                <td colspan="5" class="text-muted">No SI requests found.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                var manualCode = string.IsNullOrWhiteSpace(item.RequestedCourseSection)
                    ? item.RequestedCourseName
                    : $"{item.RequestedCourseName} ({item.RequestedCourseSection})";
                var courseDisplay = item.Course is not null
                    ? $"{item.Course.CourseName} ({item.Course.CourseSection}) - {item.Course.CourseTitle}"
                    : (!string.IsNullOrWhiteSpace(item.RequestedCourseName)
                        ? (string.IsNullOrWhiteSpace(item.RequestedCourseTitle)
                            ? manualCode
                            : $"{manualCode} - {item.RequestedCourseTitle}")
                        : "Manual Course Entry");
                var statusDisplay = item.Status switch
                {
                    schedule_ders.Models.SIRequestStatus.Pending => "Submitted",
                    schedule_ders.Models.SIRequestStatus.UnderReview => "Under Review",
                    schedule_ders.Models.SIRequestStatus.SiLeaderFound => "SI Leader Found",
                    schedule_ders.Models.SIRequestStatus.Approved => "Approved",
                    schedule_ders.Models.SIRequestStatus.Denied => "Not Moving Forward",
                    _ => item.Status.ToString()
                };
                <tr>
                    <th scope="row">@courseDisplay</th>
                    <td>@item.ProfessorName</td>
                    <td>
                        <div>@item.SubmittedAtUtc.ToLocalTime().ToString("g")</div>
                        <span class="relative-time-pill">@RelativeTime(item.SubmittedAtUtc, nowUtc)</span>
                    </td>
                    <td>
                        <span class="status-pill @(item.Status switch
                            {
                                schedule_ders.Models.SIRequestStatus.Pending => "status-pill-pending",
                                schedule_ders.Models.SIRequestStatus.UnderReview => "status-pill-review",
                                schedule_ders.Models.SIRequestStatus.Approved => "status-pill-approved",
                                schedule_ders.Models.SIRequestStatus.SiLeaderFound => "status-pill-approved",
                                _ => "status-pill-denied"
                            })">@statusDisplay</span>
                        <div class="mt-1">
                            <span class="status-pill @(item.PotentialSiLeaderStatus switch
                                {
                                    schedule_ders.Models.SILeaderReviewStatus.Approved => "status-pill-approved",
                                    schedule_ders.Models.SILeaderReviewStatus.Denied => "status-pill-denied",
                                    schedule_ders.Models.SILeaderReviewStatus.UnderReview => "status-pill-review",
                                    _ => "status-pill-pending"
                                })">Leader: @item.PotentialSiLeaderStatus</span>
                        </div>
                    </td>
                    <td class="text-nowrap text-center">
                        <a asp-action="Update"
                           asp-route-id="@item.SIRequestID"
                           class="request-action-link @((item.Status == schedule_ders.Models.SIRequestStatus.Pending || item.Status == schedule_ders.Models.SIRequestStatus.UnderReview) ? "request-action-link-priority" : "request-action-link-subtle")">Review</a>
                        @if (item.Status == schedule_ders.Models.SIRequestStatus.Approved || item.Status == schedule_ders.Models.SIRequestStatus.SiLeaderFound || item.Status == schedule_ders.Models.SIRequestStatus.Denied)
                        {
                            <button type="button"
                                    class="request-action-link request-action-delete request-action-link-inline"
                                    data-admin-request-remove-btn="true"
                                    data-request-id="@item.SIRequestID">Remove</button>
                        }
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
</section>
