@model schedule_ders.ViewModels.AdminRequestStatusUpdateViewModel
@{
    ViewData["Title"] = "Review SI Request";
}

<section class="page-shell">
<div class="page-title-row mb-1">
    <div>
        <a asp-action="Index" class="btn page-back-btn">Back</a>
    </div>
    <div class="page-title-row-main">
        <h1 class="page-title">Review SI Request</h1>
        <p class="page-subtitle">@Model.CourseDisplay</p>
    </div>
    <div></div>
</div>

<div class="row">
    <div class="col-lg-8">
        <dl class="row surface-card p-3">
            <dt class="col-sm-3">Professor</dt>
            <dd class="col-sm-9">@Model.ProfessorName (@Model.ProfessorEmail)</dd>

            <dt class="col-sm-3">Submitted</dt>
            <dd class="col-sm-9">@Model.SubmittedAtUtc.ToLocalTime().ToString("f")</dd>

            <dt class="col-sm-3">Request Notes</dt>
            <dd class="col-sm-9">@Model.RequestNotes</dd>
        </dl>
    </div>
</div>

<form asp-action="Update"
      method="post"
      class="form-card"
      data-admin-request-update-form="true"
      data-api-url="@Url.Content($"~/api/v1/admin/requests/{Model.SIRequestID}/status")"
      data-success-url="@Url.Action("Index", "AdminRequests")">
    <input type="hidden" asp-for="SIRequestID" />
    <input type="hidden" asp-for="CourseID" />
    <input type="hidden" asp-for="CourseDisplay" />
    <input type="hidden" asp-for="ProfessorName" />
    <input type="hidden" asp-for="ProfessorEmail" />
    <input type="hidden" asp-for="RequestNotes" />
    <input type="hidden" asp-for="SubmittedAtUtc" />

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" asp-items="ViewBag.Statuses" class="form-select"></select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="AdminNotes" class="form-label"></label>
        <textarea asp-for="AdminNotes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="AdminNotes" class="text-danger"></span>
    </div>

    <div class="form-submit-row">
        <button type="submit" class="btn btn-primary">Save Status</button>
    </div>
</form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
