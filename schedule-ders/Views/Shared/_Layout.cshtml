<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - schedule_ders</title>
    <script>
        (function () {
            try {
                var key = "sd-theme";
                var stored = localStorage.getItem(key);
                var prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
                var theme = (stored === "dark" || stored === "light") ? stored : (prefersDark ? "dark" : "light");
                document.documentElement.setAttribute("data-theme", theme);
            } catch (e) {
                document.documentElement.setAttribute("data-theme", "light");
            }
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/schedule_ders.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand brand-with-logo" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/schedule-ders-logo.png"
                         alt="Schedule-Ders"
                         class="brand-logo"
                         asp-append-version="true" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Courses" asp-action="Index">Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Sessions" asp-action="Index">Sessions</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="AdminRequests" asp-action="Index">SI Requests</a>
                                </li>
                            }
                            @if (User.IsInRole("Professor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="ProfessorRequests" asp-action="Index">My Requests</a>
                                </li>
                            }
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="StudentSchedule" asp-action="Index">SI Schedule</a>
                        </li>
                    </ul>

                    <button type="button"
                            class="btn btn-sm theme-toggle-btn me-2"
                            id="themeToggleBtn"
                            aria-label="Switch to dark mode"
                            title="Switch to dark mode">
                        <svg class="theme-toggle-icon" viewBox="0 0 24 24" role="img" aria-hidden="true" focusable="false">
                            <path d="M9 21h6v-1H9v1zm3-20C8.69 1 6 3.69 6 7c0 2.38 1.19 4.47 3 5.74V16c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-3.26c1.81-1.27 3-3.36 3-5.74 0-3.31-2.69-6-6-6zm1 10.93V15h-2v-3.07l-.43-.3A4.97 4.97 0 0 1 8 7c0-2.21 1.79-4 4-4s4 1.79 4 4a4.97 4.97 0 0 1-2.57 4.63l-.43.3z" />
                        </svg>
                    </button>

                    <partial name="_LoginPartial" />
                </div>

            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container footer-content">
            <span>&copy; @DateTime.UtcNow.Year</span>
            <span class="footer-brand">Schedule-Ders</span>
            <span class="footer-sep" aria-hidden="true">|</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
