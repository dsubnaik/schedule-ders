@model schedule_ders.Models.Course
@{
    ViewData["Title"] = "Course Details";

    string ExpandDayToken(string token) => token?.Trim().ToUpperInvariant() switch
    {
        "M" => "Monday",
        "T" => "Tuesday",
        "W" => "Wednesday",
        "R" => "Thursday",
        "F" => "Friday",
        _ => token ?? string.Empty
    };
}

<section class="page-shell"
         data-course-sessions-api="true"
         data-api-url="@Url.Content($"~/api/v1/courses/{Model.CourseID}/sessions")"
         data-course-id="@Model.CourseID"
         data-course-name="@Model.CourseName"
         data-course-title="@Model.CourseTitle"
         data-course-section="@Model.CourseSection"
         data-course-leader="@Model.CourseLeader"
         data-edit-url-template="@Url.Action("Edit", "Sessions", new { id = "__id__", returnUrl = Url.Action("Details","Courses", new { id = Model.CourseID }) })">
<div class="page-title-row mb-1">
    <div>
        <a asp-action="Index" class="btn page-back-btn">Back</a>
    </div>
    <div class="page-title-row-main">
        <h1 class="page-title">Course Details</h1>
    </div>
    <div class="page-actions justify-content-end">
        <a asp-action="Edit" asp-route-id="@Model.CourseID" class="btn btn-outline-primary">Edit Course</a>
    </div>
</div>

<section class="details-panel details-panel-compact">
    <div class="details-grid details-grid-standalone">
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.CourseCrn)</span>
            <span class="details-value">@Model.CourseCrn</span>
        </div>
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.CourseName)</span>
            <span class="details-value">@Model.CourseName</span>
        </div>
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.CourseTitle)</span>
            <span class="details-value">@Model.CourseTitle</span>
        </div>
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.CourseSection)</span>
            <span class="details-value">@Model.CourseSection</span>
        </div>
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.CourseProfessor)</span>
            <span class="details-value">@Model.CourseProfessor</span>
        </div>
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.CourseMeetingDays)</span>
            <span class="details-value">@Model.CourseMeetingDays</span>
        </div>
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.CourseMeetingTime)</span>
            <span class="details-value">@Model.CourseMeetingTime</span>
        </div>
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.CourseLeader)</span>
            <span class="details-value">@Model.CourseLeader</span>
        </div>
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.OfficeHoursDay)</span>
            <span class="details-value">@ExpandDayToken(Model.OfficeHoursDay)</span>
        </div>
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.OfficeHoursTime)</span>
            <span class="details-value">@Model.OfficeHoursTime</span>
        </div>
        <div class="details-item">
            <span class="details-label">@Html.DisplayNameFor(model => model.OfficeHoursLocation)</span>
            <span class="details-value">@Model.OfficeHoursLocation</span>
        </div>
    </div>
</section>

<div class="page-header mt-2 mb-1">
    <h2 class="h4 mb-0">Sessions</h2>
    <a asp-controller="Sessions" asp-action="Create" asp-route-courseId="@Model.CourseID" asp-route-returnUrl="@Url.Action("Details","Courses", new { id = Model.CourseID })" class="btn btn-primary btn-sm">Add Session</a>
</div>

<div class="row g-3" data-course-sessions-cards="true">
@if (Model.Sessions.Count == 0)
{
    <div class="col-12">
        <div class="empty-state">
            <p class="empty-state-title">No sessions added yet.</p>
        </div>
    </div>
}
else
{
    @foreach (var session in Model.Sessions)
    {
        <div class="col-12 col-md-6 col-lg-4">
            <article class="card h-100 shadow-sm student-course-card">
                <div class="card-body">
                                <div class="session-card-top mb-2">
                                    <h3 class="h4 mb-0">
                                        <span class="fw-bold">@Model.CourseName</span>
                                        @if (!string.IsNullOrWhiteSpace(Model.CourseTitle))
                                        {
                                            <span class="text-muted"> - @Model.CourseTitle</span>
                                        }
                                    </h3>
                                </div>
                    <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                        <span class="badge session-meta-badge session-meta-badge-sections">Sections @Model.CourseSection</span>
                        <span class="badge session-meta-badge session-meta-badge-leader">SI Leader: @Model.CourseLeader</span>
                    </div>
                    <div class="student-session-item session-card-slot mb-2">
                        <span class="student-session-day">@session.Day</span>
                        <span class="student-session-time">@session.Time</span>
                        <span class="student-session-location">@session.Location</span>
                    </div>
                    <div class="session-card-actions-row">
                        <div class="professor-request-actions">
                            <a asp-controller="Sessions"
                               asp-action="Edit"
                               asp-route-id="@session.SessionID"
                               asp-route-returnUrl="@Url.Action("Details","Courses", new { id = Model.CourseID })"
                               class="request-action-link request-action-link-compact">Edit</a>
                            <a asp-action="Details"
                               asp-route-id="@Model.CourseID"
                               class="request-action-link request-action-link-compact">Course</a>
                            <button type="button"
                                    class="request-action-link request-action-delete request-action-link-compact"
                                    data-session-delete-trigger="true"
                                    data-session-id="@session.SessionID"
                                    data-session-ids="@session.SessionID"
                                    data-session-display="@($"{Model.CourseName} ({Model.CourseSection}) - {Model.CourseTitle} {session.Day} {session.Time}")"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteSessionModal">Delete</button>
                        </div>
                    </div>
                </div>
            </article>
        </div>
    }
}
</div>
</section>

<div class="modal fade" id="deleteSessionModal" tabindex="-1" aria-labelledby="deleteSessionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content request-delete-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteSessionModalLabel">Delete Session Slot</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">Are you sure you want to delete this session slot?</p>
                <p class="mb-0 text-muted"><strong>Session:</strong> <span id="deleteSessionName">-</span></p>
            </div>
            <div class="modal-footer">
                <form asp-controller="Sessions" asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteSessionIdInput" />
                    <input type="hidden" name="sessionIds" id="deleteSessionIdsInput" />
                    <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Courses", new { id = Model.CourseID })" />
                    <button type="submit" class="btn btn-danger">Delete Slot</button>
                </form>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>
