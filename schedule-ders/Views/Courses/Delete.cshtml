@model schedule_ders.Models.Course
@{
    ViewData["Title"] = "Delete Course";
}

<section class="page-shell">
<h1 class="page-title">Delete Course</h1>
<p class="text-danger">This will also remove all sessions under this course.</p>

<dl class="row surface-card p-3">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CourseCrn)</dt>
    <dd class="col-sm-9">@Model.CourseCrn</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CourseName)</dt>
    <dd class="col-sm-9">@Model.CourseName</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CourseSection)</dt>
    <dd class="col-sm-9">@Model.CourseSection</dd>

    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CourseProfessor)</dt>
    <dd class="col-sm-9">@Model.CourseProfessor</dd>
</dl>

<form asp-action="Delete" method="post" class="form-card">
    <input type="hidden" asp-for="CourseID" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
</section>
