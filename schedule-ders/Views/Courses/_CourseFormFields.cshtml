@model schedule_ders.Models.Course
@{
    var professorOptions = ViewBag.ProfessorOptions as List<string> ?? [];
    var minutes = new[] { 0, 15, 30, 45, 50 };
    var timeOptions = new List<string>();
    var officeHoursDayValue = (Model.OfficeHoursDay ?? string.Empty).Trim();
    bool IsOfficeDaySelected(params string[] values) =>
        values.Any(v => string.Equals(officeHoursDayValue, v, StringComparison.OrdinalIgnoreCase));
    for (var hour = 7; hour <= 22; hour++)
    {
        foreach (var minute in minutes)
        {
            var dt = new DateTime(2000, 1, 1, hour, minute, 0);
            timeOptions.Add(dt.ToString("h:mmtt").ToLowerInvariant());
        }
    }
}

<input type="hidden"
       id="courseFormConfig"
       data-course-form-enhancer="true"
       data-lookup-url="@Url.Action("LookupByCrn", "Courses")"
       data-leader-lookup-url="@Url.Action("LookupLeaderByCourseName", "Courses")"
       data-exclude-id="@Model.CourseID" />

<div class="mb-3">
    <label asp-for="CourseCrn" class="form-label"></label>
    <div class="input-group">
        <input asp-for="CourseCrn" class="form-control" placeholder="12345" id="courseCrnInput" />
        <button type="button" class="btn btn-outline-secondary" id="lookupCrnBtn">Auto-fill</button>
    </div>
    <div class="form-text">Enter CRN and click Auto-fill to load course name and section from saved CRN catalog.</div>
    <span asp-validation-for="CourseCrn" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CourseName" class="form-label"></label>
    <input asp-for="CourseName" class="form-control" id="courseNameInput" />
    <span asp-validation-for="CourseName" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CourseSection" class="form-label"></label>
    <input asp-for="CourseSection" class="form-control" id="courseSectionInput" />
    <span asp-validation-for="CourseSection" class="text-danger"></span>
</div>

<input asp-for="CourseMeetingDays" type="hidden" id="courseMeetingDaysInput" />
<div class="mb-3">
    <label class="form-label">Meeting Day(s)</label>
    <div class="d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-outline-primary day-toggle" data-day="M">M</button>
        <button type="button" class="btn btn-outline-primary day-toggle" data-day="T">T</button>
        <button type="button" class="btn btn-outline-primary day-toggle" data-day="W">W</button>
        <button type="button" class="btn btn-outline-primary day-toggle" data-day="R">R</button>
        <button type="button" class="btn btn-outline-primary day-toggle" data-day="F">F</button>
    </div>
    <div class="form-text">Click one or more days.</div>
    <span asp-validation-for="CourseMeetingDays" class="text-danger"></span>
</div>

<input asp-for="CourseMeetingTime" type="hidden" id="courseMeetingTimeInput" />
<div class="mb-3">
    <label class="form-label">Meeting Time</label>
    <div class="row g-2">
        <div class="col-6">
            <label class="form-label small mb-1">Start</label>
            <select id="meetingStartInput" class="form-select">
                <option value="">Start time</option>
                @foreach (var t in timeOptions)
                {
                    <option value="@t">@t</option>
                }
            </select>
        </div>
        <div class="col-6">
            <label class="form-label small mb-1">End</label>
            <select id="meetingEndInput" class="form-select">
                <option value="">End time</option>
                @foreach (var t in timeOptions)
                {
                    <option value="@t">@t</option>
                }
            </select>
        </div>
    </div>
    <span asp-validation-for="CourseMeetingTime" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CourseProfessor" class="form-label"></label>
    <input asp-for="CourseProfessor" class="form-control" list="professorOptions" id="courseProfessorInput" />
    <datalist id="professorOptions">
        @foreach (var professor in professorOptions)
        {
            <option value="@professor"></option>
        }
    </datalist>
    <div class="form-text">Search existing professors or type a new one.</div>
    <span asp-validation-for="CourseProfessor" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="CourseLeader" class="form-label"></label>
    <input asp-for="CourseLeader" class="form-control" id="courseLeaderInput" />
    <span asp-validation-for="CourseLeader" class="text-danger"></span>
</div>

<input asp-for="OfficeHoursTime" type="hidden" id="officeHoursTimeInput" />
<div class="card border-secondary-subtle mb-3">
    <div class="card-body">
        <h2 class="h6 mb-3">Office Hours</h2>
        <div class="mb-3">
            <label asp-for="OfficeHoursDay" class="form-label"></label>
            <select asp-for="OfficeHoursDay" class="form-select" id="officeHoursDayInput">
                <option value="">Select day</option>
                <option value="Monday" selected="@(IsOfficeDaySelected("Monday", "M") ? "selected" : null)">Monday</option>
                <option value="Tuesday" selected="@(IsOfficeDaySelected("Tuesday", "T") ? "selected" : null)">Tuesday</option>
                <option value="Wednesday" selected="@(IsOfficeDaySelected("Wednesday", "W") ? "selected" : null)">Wednesday</option>
                <option value="Thursday" selected="@(IsOfficeDaySelected("Thursday", "R") ? "selected" : null)">Thursday</option>
                <option value="Friday" selected="@(IsOfficeDaySelected("Friday", "F") ? "selected" : null)">Friday</option>
            </select>
            <span asp-validation-for="OfficeHoursDay" class="text-danger"></span>
        </div>
        <div class="row g-2 mb-3">
            <div class="col-6">
                <label class="form-label small mb-1">Start</label>
                <select id="officeStartInput" class="form-select">
                    <option value="">Start time</option>
                    @foreach (var t in timeOptions)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <div class="col-6">
                <label class="form-label small mb-1">End</label>
                <select id="officeEndInput" class="form-select">
                    <option value="">End time</option>
                    @foreach (var t in timeOptions)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <span asp-validation-for="OfficeHoursTime" class="text-danger"></span>
        </div>
        <div class="mb-0">
            <label asp-for="OfficeHoursLocation" class="form-label"></label>
            <input asp-for="OfficeHoursLocation" class="form-control" id="officeHoursLocationInput" placeholder="Library" />
            <span asp-validation-for="OfficeHoursLocation" class="text-danger"></span>
        </div>
    </div>
</div>
