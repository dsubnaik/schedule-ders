@model schedule_ders.Models.Course
@{
    var professorOptions = ViewBag.ProfessorOptions as List<string> ?? [];
    var leaderOptions = ViewBag.LeaderOptions as List<string> ?? [];
    var courseNameOptions = ViewBag.CourseNameOptions as List<string> ?? [];
    var semesterOptions = ViewBag.SemesterOptions as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var minutes = new[] { 0, 15, 30, 45, 50 };
    var timeOptions = new List<string>();
    for (var hour = 7; hour <= 22; hour++)
    {
        foreach (var minute in minutes)
        {
            var dt = new DateTime(2000, 1, 1, hour, minute, 0);
            timeOptions.Add(dt.ToString("h:mmtt").ToLowerInvariant());
        }
    }
}

<input type="hidden"
       id="courseFormConfig"
       data-course-form-enhancer="true"
       data-leader-lookup-url="@Url.Action("LookupLeaderByCourseName", "Courses")"
       data-office-hours-lookup-url="@Url.Action("LookupOfficeHoursByLeader", "Courses")"
       data-exclude-id="@Model.CourseID" />

<div class="mb-3">
    <label asp-for="CourseCrn" class="form-label" for="courseCrnInput"></label>
    <input asp-for="CourseCrn" class="form-control" placeholder="12345" id="courseCrnInput" />
    <span asp-validation-for="CourseCrn" class="text-danger"></span>
</div>

<div class="row g-3">
    <div class="col-12 col-md-3">
        <label asp-for="SemesterId" class="form-label"></label>
        <select asp-for="SemesterId" class="form-select" asp-items="semesterOptions">
            <option value="">Select semester</option>
        </select>
        <span asp-validation-for="SemesterId" class="text-danger"></span>
    </div>
    <div class="col-12 col-md-4">
        <label asp-for="CourseName" class="form-label" for="courseNameInput"></label>
        <input asp-for="CourseName" class="form-control" id="courseNameInput" list="courseNameOptions" />
        <span asp-validation-for="CourseName" class="text-danger"></span>
    </div>
    <div class="col-12 col-md-5">
        <label asp-for="CourseTitle" class="form-label" for="courseTitleInput"></label>
        <input asp-for="CourseTitle" class="form-control" id="courseTitleInput" />
        <span asp-validation-for="CourseTitle" class="text-danger"></span>
    </div>
    <div class="col-12 col-md-3">
        <label asp-for="CourseSection" class="form-label" for="courseSectionInput"></label>
        <input asp-for="CourseSection" class="form-control" id="courseSectionInput" />
        <span asp-validation-for="CourseSection" class="text-danger"></span>
    </div>
</div>

<datalist id="courseNameOptions">
    @foreach (var courseName in courseNameOptions)
    {
        <option value="@courseName"></option>
    }
</datalist>

<input asp-for="CourseMeetingDays" type="hidden" id="courseMeetingDaysInput" />
<fieldset class="mb-3">
    <legend class="form-label mb-2">Meeting Day(s)</legend>
    <div class="d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-outline-primary day-toggle" data-day="M">M</button>
        <button type="button" class="btn btn-outline-primary day-toggle" data-day="T">T</button>
        <button type="button" class="btn btn-outline-primary day-toggle" data-day="W">W</button>
        <button type="button" class="btn btn-outline-primary day-toggle" data-day="R">R</button>
        <button type="button" class="btn btn-outline-primary day-toggle" data-day="F">F</button>
    </div>
    <div class="form-text">Click one or more days.</div>
    <span asp-validation-for="CourseMeetingDays" class="text-danger"></span>
</fieldset>

<input asp-for="CourseMeetingTime" type="hidden" id="courseMeetingTimeInput" />
<fieldset class="mb-3">
    <legend class="form-label mb-2">Lecture Time</legend>
    <div class="row g-2">
        <div class="col-6">
            <label class="form-label small mb-1" for="meetingStartInput">Start</label>
            <div class="time-picker">
                <input type="text"
                       id="meetingStartInput"
                       class="form-control time-picker-input"
                       data-time-options="courseTimeOptions"
                       autocomplete="off"
                       placeholder="Start time (e.g. 9:00am)" />
                <div class="time-picker-menu" data-time-picker-menu="true"></div>
            </div>
        </div>
        <div class="col-6">
            <label class="form-label small mb-1" for="meetingEndInput">End</label>
            <div class="time-picker">
                <input type="text"
                       id="meetingEndInput"
                       class="form-control time-picker-input"
                       data-time-options="courseTimeOptions"
                       data-suggest-from="meetingStartInput"
                       data-suggest-offsets="50,75"
                       autocomplete="off"
                       placeholder="Choose or enter end time" />
                <div class="time-picker-menu" data-time-picker-menu="true"></div>
            </div>
        </div>
    </div>
    <span asp-validation-for="CourseMeetingTime" class="text-danger"></span>
</fieldset>

<datalist id="courseTimeOptions">
    @foreach (var t in timeOptions)
    {
        <option value="@t"></option>
    }
</datalist>

<div class="row g-3 mb-3">
    <div class="col-12 col-md-6">
        <label asp-for="CourseProfessor" class="form-label" for="courseProfessorInput"></label>
        <input asp-for="CourseProfessor" class="form-control" list="professorOptions" id="courseProfessorInput" />
        <span asp-validation-for="CourseProfessor" class="text-danger"></span>
    </div>
    <div class="col-12 col-md-6">
        <label asp-for="CourseLeader" class="form-label" for="courseLeaderInput"></label>
        <input asp-for="CourseLeader" class="form-control" id="courseLeaderInput" list="courseLeaderOptions" />
        <span asp-validation-for="CourseLeader" class="text-danger"></span>
    </div>
</div>
<datalist id="professorOptions">
    @foreach (var professor in professorOptions)
    {
        <option value="@professor"></option>
    }
</datalist>
<datalist id="courseLeaderOptions">
    @foreach (var leader in leaderOptions)
    {
        <option value="@leader"></option>
    }
</datalist>
<div class="form-text mb-3">Search existing professors or type a new one.</div>

<input asp-for="OfficeHoursDay" type="hidden" id="officeHoursDayInput" />
<input asp-for="OfficeHoursTime" type="hidden" id="officeHoursTimeInput" />
<div class="card border-secondary-subtle mb-3">
    <div class="card-body">
        <h2 class="h6 mb-3">Office Hours</h2>
        <fieldset class="mb-3">
            <legend class="form-label mb-2">@Html.DisplayNameFor(model => model.OfficeHoursDay)</legend>
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-outline-primary office-day-toggle" data-day="M">M</button>
                <button type="button" class="btn btn-outline-primary office-day-toggle" data-day="T">T</button>
                <button type="button" class="btn btn-outline-primary office-day-toggle" data-day="W">W</button>
                <button type="button" class="btn btn-outline-primary office-day-toggle" data-day="R">R</button>
                <button type="button" class="btn btn-outline-primary office-day-toggle" data-day="F">F</button>
            </div>
            <span asp-validation-for="OfficeHoursDay" class="text-danger"></span>
        </fieldset>
        <fieldset class="row g-2 mb-3">
            <legend class="form-label mb-0">Office Hours Time</legend>
            <div class="col-6">
                <label class="form-label small mb-1" for="officeStartInput">Start</label>
                <div class="time-picker">
                    <input type="text"
                           id="officeStartInput"
                           class="form-control time-picker-input"
                           data-time-options="officeTimeOptions"
                           autocomplete="off"
                           placeholder="Start time (e.g. 2:00pm)" />
                    <div class="time-picker-menu" data-time-picker-menu="true"></div>
                </div>
            </div>
            <div class="col-6">
                <label class="form-label small mb-1" for="officeEndInput">End</label>
                <div class="time-picker">
                    <input type="text"
                           id="officeEndInput"
                           class="form-control time-picker-input"
                           data-time-options="officeTimeOptions"
                           autocomplete="off"
                           placeholder="End time (e.g. 3:00pm)" />
                    <div class="time-picker-menu" data-time-picker-menu="true"></div>
                </div>
            </div>
            <span asp-validation-for="OfficeHoursTime" class="text-danger"></span>
        </fieldset>
        <div class="mb-0">
            <label asp-for="OfficeHoursLocation" class="form-label" for="officeHoursLocationInput"></label>
            <input asp-for="OfficeHoursLocation" class="form-control" id="officeHoursLocationInput" placeholder="Library" />
            <span asp-validation-for="OfficeHoursLocation" class="text-danger"></span>
        </div>
    </div>
</div>

<datalist id="officeTimeOptions">
    @foreach (var t in timeOptions)
    {
        <option value="@t"></option>
    }
</datalist>
