@{
    ViewData["Title"] = "Privacy Policy";
}
<section class="page-shell">
    <div class="page-header mb-1">
        <h1 class="page-title">@ViewData["Title"]</h1>
    </div>

    <div class="surface-card p-3">
        <p>
            Schedule-Ders stores the account and scheduling information needed to provide SI request tracking,
            course management, session scheduling, and student schedule lookup.
        </p>

        <h2 class="h5 mt-3">Information We Store</h2>
        <p class="mb-2">
            This may include your name, email address, role in the system, course details, SI session details,
            request notes, candidate information, and related administrative updates.
        </p>

        <h2 class="h5 mt-3">How We Use It</h2>
        <p class="mb-2">
            We use this information only to operate the application, support scheduling workflows, review SI requests,
            and help authorized users manage courses, sessions, and SI leader activity.
        </p>

        <h2 class="h5 mt-3">Access and Sharing</h2>
        <p class="mb-2">
            Information is intended for use by authorized students, professors, SI leaders, and administrators within
            the system. Data is not meant to be publicly shared through this application.
        </p>

        <h2 class="h5 mt-3">Contact</h2>
        <p class="mb-0">
            If your organization needs a more detailed privacy statement, retention policy, or contact information,
            this page can be updated with your official policy language.
        </p>
    </div>
</section>
