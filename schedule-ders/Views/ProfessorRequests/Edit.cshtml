@model schedule_ders.ViewModels.ProfessorRequestCreateViewModel
@{
    ViewData["Title"] = "Edit SI Request";
    var requestId = ViewContext.RouteData.Values["id"]?.ToString();
}

<section class="page-shell new-request-page">
<div class="page-title-row mb-1">
    <div>
        <a asp-action="Index" class="btn page-back-btn">Back</a>
    </div>
    <div class="page-title-row-main">
        <h1 class="page-title">Edit SI Request</h1>
    </div>
    <div></div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <form asp-action="Edit"
              asp-route-id="@requestId"
              method="post"
              class="form-card"
              data-professor-request-form="true">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <partial name="_ProfessorRequestFormFields" model="Model" />

            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Details" asp-route-id="@requestId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
