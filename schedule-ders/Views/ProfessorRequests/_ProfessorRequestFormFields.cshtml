@model schedule_ders.ViewModels.ProfessorRequestCreateViewModel
@{
    var courseCodeOptions = ViewBag.CourseCodeOptions as List<string> ?? [];
    var courseTitleOptions = ViewBag.CourseTitleOptions as List<string> ?? [];
    var siLeaderOptions = ViewBag.SiLeaderOptions as List<string> ?? [];
    var leaderCandidates = (Model.PotentialSiLeaderName ?? string.Empty)
        .Replace("\r", "\n")
        .Split(new[] { '\n', ';', ',' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();
    if (leaderCandidates.Count == 0)
    {
        leaderCandidates.Add(string.Empty);
    }
}

<input asp-for="CourseID" type="hidden" />
<input asp-for="RequestedCourseProfessor" type="hidden" />

<div class="mb-3">
    <label asp-for="RequestedCourseName" class="form-label"></label>
    <input asp-for="RequestedCourseName"
           class="form-control"
           placeholder="Start typing course code"
           list="courseCodeOptions"
           autocomplete="off" />
    <datalist id="courseCodeOptions">
        @foreach (var courseCode in courseCodeOptions)
        {
            <option value="@courseCode"></option>
        }
    </datalist>
    <div class="form-text">Pick an existing course code from suggestions or enter a new one.</div>
    <span asp-validation-for="RequestedCourseName" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="RequestedCourseTitle" class="form-label"></label>
    <input asp-for="RequestedCourseTitle"
           class="form-control"
           placeholder="Start typing course name"
           list="courseTitleOptions"
           autocomplete="off" />
    <datalist id="courseTitleOptions">
        @foreach (var courseTitle in courseTitleOptions)
        {
            <option value="@courseTitle"></option>
        }
    </datalist>
    <span asp-validation-for="RequestedCourseTitle" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="RequestedCourseSection" class="form-label"></label>
    <input asp-for="RequestedCourseSection" class="form-control" placeholder="Type section number (e.g. 001)" autocomplete="off" />
    <span asp-validation-for="RequestedCourseSection" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="RequestNotes" class="form-label"></label>
    <textarea asp-for="RequestNotes" class="form-control" rows="6" placeholder="Describe why SI support is requested, target students, and preferred timing."></textarea>
    <span asp-validation-for="RequestNotes" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="PotentialSiLeaderName" class="form-label"></label>
    <input asp-for="PotentialSiLeaderName" type="hidden" />
    <div data-potential-leader-list="true" class="d-flex flex-column gap-2">
        @foreach (var candidate in leaderCandidates)
        {
            var candidateInputId = $"potentialSiLeader_{Guid.NewGuid():N}";
            <div class="input-group" data-potential-leader-row="true">
                <label class="visually-hidden" for="@candidateInputId">Suggested SI leader candidate</label>
                <input type="text"
                       id="@candidateInputId"
                       class="form-control"
                       data-potential-leader-input="true"
                       list="siLeaderOptions"
                       placeholder="Optional: suggest a student for SI leader"
                       autocomplete="off"
                       value="@candidate" />
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-remove-potential-leader="true">Remove</button>
            </div>
        }
    </div>
    <button type="button" class="btn btn-outline-primary btn-sm mt-2" data-add-potential-leader="true">Add Candidate</button>
    <datalist id="siLeaderOptions">
        @foreach (var leader in siLeaderOptions)
        {
            <option value="@leader"></option>
        }
    </datalist>
    <span asp-validation-for="PotentialSiLeaderName" class="text-danger"></span>
</div>
